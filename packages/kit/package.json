{
  "name": "usecalibrate",
  "version": "0.1.3",
  "description": "Self-hosted, position-only onboarding instrumentation SDK",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ojusave/usecalibrate.git",
    "directory": "packages/kit"
  },
  "homepage": "https://github.com/ojusave/usecalibrate#readme",
  "bugs": {
    "url": "https://github.com/ojusave/usecalibrate/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/browser.js",
  "types": "./dist/browser.d.ts",
  "exports": {
    ".": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./manifest": {
      "types": "./dist/manifest.d.ts",
      "import": "./dist/manifest.js"
    },
    "./reducer": {
      "types": "./dist/reducer.d.ts",
      "import": "./dist/reducer.js"
    },
    "./snapshot": {
      "types": "./dist/snapshot.d.ts",
      "import": "./dist/snapshot.js"
    },
    "./tracker": {
      "types": "./dist/tracker.d.ts",
      "import": "./dist/tracker.mjs"
    },
    "./version": {
      "types": "./dist/version.d.ts",
      "import": "./dist/version.js"
    }
  },
  "bin": {
    "calibrate": "dist/cli.js",
    "calibrate-sidecar": "dist/sidecar.js",
    "usecalibrate": "dist/cli.js"
  },
  "files": [
    "dist",
    "present",
    "skills",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && npm run build:tracker",
    "build:tracker": "node ../../scripts/build-tracker.mjs",
    "test": "cd ../.. && vitest run --config vitest.config.ts",
    "test:watch": "cd ../.. && vitest --config vitest.config.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.10",
    "hono": "^4.12.30"
  }
}
